{
  "name": "omni-color",
  "description": "A modern TypeScript color library for parsing, converting, manipulating, palettes, and accessibility.",
  "version": "0.1.0",
  "homepage": "https://rteammco.github.io/omni-color/",
  "license": "ISC",
  "author": "Richard Teammco",
  "keywords": [
    "color",
    "typescript",
    "javascript",
    "color-library",
    "color-parsing",
    "color-conversion",
    "color-manipulation",
    "color-gradient",
    "color-scale",
    "color-harmony",
    "color-palette",
    "css-color",
    "color-space",
    "oklch",
    "lab",
    "lch",
    "wcag",
    "apca",
    "immutable",
    "contrast",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rteammco/omni-color.git"
  },
  "bugs": {
    "url": "https://github.com/rteammco/omni-color/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "npm run lint:lib && npm run lint:demo",
    "lint:lib": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:demo": "npm run lint --prefix demo",
    "typecheck": "tsc",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --tsconfig tsconfig.json --watch",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --tsconfig tsconfig.json",
    "prepublishOnly": "npm run build",
    "install:demo": "npm install --prefix demo",
    "dev:demo": "npm run build && npm run dev --prefix demo",
    "build:demo": "npm run build && npm run build --prefix demo"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^30.0.0",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "chroma-js": "^3.2.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.13.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tinycolor2": "^1.6.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
